<file path="roles/win_dc_dns/README.md">
# AD Domain Controller / DNS — Ansible Role
This role deploys Windows **Active Directory Domain Services** (AD DS) + **DNS** for the competition domain and supports Team 1 / Team 2 / all-team deployments from one unified workflow.

The role now:
1. Installs AD DS + DNS features
2. Creates or ensures the `lakeplacid.local` domain
3. Creates the competition OU and security group
4. Creates all required domain users (shared + team-specific)
5. Adds admin-designated domain users (`is_admin: true` in `windows_domain_team_users`) to **Domain Admins**
6. Creates DNS A records for team hosts based on selected deployment scope

### Control Machine
- Ansible 2.11+
- WinRM configured on target Windows host
- Python installed (on control machine)
- Required Ansible Collections:
  ```sh
  ansible-galaxy collection install ansible.windows
  ansible-galaxy collection install microsoft.ad
  ```

## Deployment Commands
From `ansible/`:

You can also run through the main playbook:
```sh
ansible-playbook -i inventory.yml site.yml -e windows_dc_deployment_team=blue_team_1
```

### Windows DC DNS Deployment
Deploy both teams:
```sh
ansible-playbook -i inventory.yml roles/win_dc_dns/deploy_dc.yml -e windows_dc_deployment_team=all
```

Deploy Team 1 only:
```sh
ansible-playbook -i inventory.yml roles/win_dc_dns/deploy_dc.yml -e windows_dc_deployment_team=blue_team_1
```

Deploy Team 2 only:
```sh
ansible-playbook -i inventory.yml roles/win_dc_dns/deploy_dc.yml -e windows_dc_deployment_team=blue_team_2
```
</file>

<file path="roles/win_dc_dns/tasks/main.yml">
---
# Windows Domain Controller + DNS Role
# Installs AD DS/DNS, creates domain, provisions team users, and creates DNS A records.

- name: Set DC hostname
  ansible.windows.win_hostname:
    name: "{{ dc_hostname }}"
  register: rename_result

- name: Reboot if hostname change requires it
  ansible.windows.win_reboot:
    msg: "Rebooting after hostname changes"
  when: rename_result.reboot_required

- name: Install Active Directory Domain Services (ADDS)
  ansible.windows.win_feature:
    name: AD-Domain-Services
    state: present
    include_management_tools: true
  register: ad_feature_result

- name: Install DNS
  ansible.windows.win_feature:
    name: DNS
    state: present
    include_management_tools: true
  register: dns_feature_result

- name: Reboot after ADDS/DNS feature install if needed
  ansible.windows.win_reboot:
    msg: "Rebooting after ADDS/DNS feature install"
  when: (ad_feature_result.reboot_required | default(false)) or (dns_feature_result.reboot_required | default(false))

- name: Create AD domain and reboot
  microsoft.ad.domain:
    dns_domain_name: "{{ domain_name }}"
    domain_netbios_name: "{{ netbios_name }}"
    safe_mode_password: "{{ safe_mode_password }}"
    create_dns_delegation: false
    install_dns: true
    reboot: true
  register: domain_create

- name: Reboot after domain creation / DC promotion if needed
  ansible.windows.win_reboot:
    msg: "Rebooting after domain creation / DC promotion"
  when: domain_create.reboot_required | default(true)

- name: Set deployment team for this DC host
  ansible.builtin.set_fact:
    selected_team: "{{ deployment_team | default(dc_team) }}"

- name: Build domain DN path
  ansible.builtin.set_fact:
    domain_dn: "DC={{ (domain_name | trim).split('.') | join(',DC=') }}"

- name: Create OU
  microsoft.ad.ou:
    name: "{{ ou_name }}"
    path: "{{ domain_dn }}"
    state: present

- name: Create group in OU
  microsoft.ad.group:
    name: "{{ group_name }}"
    path: "OU={{ ou_name }},{{ domain_dn }}"
    scope: global
    state: present

- name: Build effective domain user list
  ansible.builtin.set_fact:
    effective_domain_users: >-
      {{
        windows_domain_common_users +
        (
          windows_domain_team_users
          if selected_team == 'all' or selected_team == dc_team
          else []
        )
      }}

- name: Create domain users in OU
  microsoft.ad.user:
    name: "{{ item.sam }}"
    firstname: "{{ item.given }}"
    lastname: "{{ item.surname }}"
    password: "{{ item.password }}"
    path: "OU={{ ou_name }},{{ domain_dn }}"
    enabled: true
    state: present
  loop: "{{ effective_domain_users }}"

- name: Add privileged domain users to Domain Admins
  ansible.windows.win_powershell:
    script: |
      Import-Module ActiveDirectory
      Add-ADGroupMember -Identity "Domain Admins" -Members "{{ item.sam }}" -ErrorAction SilentlyContinue
  loop: "{{ effective_domain_users | selectattr('is_admin', 'equalto', true) | list }}"

- name: Build effective DNS A record list
  ansible.builtin.set_fact:
    effective_dns_records: >-
      {{
        (
          windows_dc.dns_records.blue_team_1 + windows_dc.dns_records.blue_team_2
        )
        if selected_team == 'all'
        else windows_dc.dns_records[selected_team]
      }}

- name: Create DNS A records for deployment hosts
  ansible.windows.win_powershell:
    script: |
      $zone = "{{ domain_name }}"
      $recordName = "{{ item.name }}"
      $recordIP = "{{ item.ip }}"
      $existing = Get-DnsServerResourceRecord -ZoneName $zone -Name $recordName -RRType "A" -ErrorAction SilentlyContinue
      if (-not $existing) {
        Add-DnsServerResourceRecordA -Name $recordName -ZoneName $zone -IPv4Address $recordIP -CreatePtr:$false
      } else {
        $currentIPs = @($existing.RecordData | ForEach-Object { $_.IPv4Address.ToString() })
        if ($currentIPs -notcontains $recordIP) {
          Remove-DnsServerResourceRecord -ZoneName $zone -Name $recordName -RRType "A" -Force -ErrorAction SilentlyContinue
          Add-DnsServerResourceRecordA -Name $recordName -ZoneName $zone -IPv4Address $recordIP -CreatePtr:$false
        }
      }
  loop: "{{ effective_dns_records }}"
</file>

<file path="roles/win_domain_join/tasks/main.yml">
---
# Join Windows Server member to AD (2016 / 2019 / 2022). Run after team DC exists.
# Requires: team_domain_controller_ip, ad_domain, ad_domain_join, windows_dc.netbios_name, microsoft.ad collection
# After joining, team admin users are added to local Administrators and all team users
# to Remote Desktop Users so they can access this Windows member the same way they can Linux.

- name: Join Windows Server to Active Directory
  when: windows_ad_domain_join | default(false)
  block:
    # Prefer default-route interface (works on Server Core and full GUI; avoids adapter-name edge cases).
    - name: Point DNS at team domain controller
      ansible.windows.win_powershell:
        script: |
          $dcIP = "{{ team_domain_controller_ip }}"
          $routes = Get-NetRoute -DestinationPrefix '0.0.0.0/0' -ErrorAction SilentlyContinue |
            Sort-Object -Property RouteMetric
          if ($routes) {
            $routes | ForEach-Object {
              Set-DnsClientServerAddress -InterfaceIndex $_.InterfaceIndex -ServerAddresses @($dcIP, '1.1.1.1')
            }
          } else {
            Get-NetAdapter | Where-Object { $_.Status -eq 'Up' } | ForEach-Object {
              Set-DnsClientServerAddress -InterfaceIndex $_.InterfaceIndex -ServerAddresses @($dcIP, '1.1.1.1')
            }
          }

    # Use the DC DNS hostname (not raw IP) for domain_server — passing only an IP can produce
    # "This operation is only allowed for the Primary Domain Controller" / odd domain\IP errors.
    # Client DNS is already pointed at team_domain_controller_ip; _ldap._tcp / A for the DC should resolve.
    - name: Join Active Directory domain
      microsoft.ad.membership:
        dns_domain_name: "{{ ad_domain }}"
        domain_admin_user: "{{ windows_dc.netbios_name }}\\{{ ad_domain_join.username }}"
        domain_admin_password: "{{ ad_domain_join.password }}"
        domain_server: "{{ team_domain_controller }}.{{ ad_domain }}"
        state: domain
        reboot: true

- name: Add team admin domain accounts to local Administrators on Windows members
  when: windows_ad_domain_join | default(false)
  ansible.windows.win_group_membership:
    name: Administrators
    members:
      - "{{ windows_dc.netbios_name }}\\{{ item.sam }}"
    state: present
  loop: "{{ windows_domain_team_users | default([]) | selectattr('is_admin', 'equalto', true) | list }}"
  loop_control:
    label: "{{ item.sam }}"
  failed_when: false

- name: Add all team domain accounts to Remote Desktop Users on Windows members
  when: windows_ad_domain_join | default(false)
  ansible.windows.win_group_membership:
    name: Remote Desktop Users
    members:
      - "{{ windows_dc.netbios_name }}\\{{ item.sam }}"
    state: present
  loop: "{{ windows_domain_team_users | default([]) }}"
  loop_control:
    label: "{{ item.sam }}"
  failed_when: false
</file>

