<file path="deploy_ssh_key.yml">
---
# Install your SSH public key on Linux targets for password-less Ansible runs.
#
# Requires sshpass on the Ansible control node when using ansible_password (see group_vars/blue_linux.yml).
#
# Default mode forces password-only SSH (no pubkey), for fresh hosts with PasswordAuthentication.
#
# If sshd uses AuthenticationMethods publickey,password (both required), password-only clients cannot
# connect. Then run with:
#   -e deploy_ssh_force_password_only=false
#   -e ansible_ssh_private_key_file=/path/to/key_already_in_authorized_keys
# (plus ansible_password from group_vars for the second factor, if required).
#
# Usage (from ansible/):
#   ansible-playbook -i inventory.yml deploy_ssh_key.yml -e ssh_public_key_file=$HOME/.ssh/id_ed25519.pub
#
# Or use scripts/deploy-ssh-keys.sh which picks a default key path.

- name: Deploy SSH public key to Linux hosts
  hosts: "{{ target_group | default('blue_linux') }}"
  gather_facts: false
  become: false
  vars:
    # When true: only password auth (typical bootstrap). When false: allow pubkey so sshd can require publickey+password.
    deploy_ssh_force_password_only: true
    deploy_ssh_args_password_only: "-o StrictHostKeyChecking=no -o PreferredAuthentications=password -o PubkeyAuthentication=no"
    deploy_ssh_args_pubkey_ok: "-o StrictHostKeyChecking=no"
    ansible_ssh_common_args: "{{ (deploy_ssh_force_password_only | bool) | ternary(deploy_ssh_args_password_only, deploy_ssh_args_pubkey_ok) }}"
  tasks:
    - name: Ensure bootstrap user has controller public key
      ansible.builtin.authorized_key:
        user: "{{ bootstrap_user.username }}"
        state: present
        key: "{{ lookup('file', ssh_public_key_file) }}"
</file>

<file path="group_vars/all.yml">
# Common variables for all hosts
# Do not set ansible_user / ansible_connection here — Linux uses bootstrap_user (cyberrange) in
# blue_linux.yml; Windows uses WinRM in blue_windows.yml / windows_dc.yml. A global ansible_user
# breaks Linux SSH (Gathering Facts) if it overrides cyberrange.

default_password: "Password123!"
admin_def_passwd: "ChangeThisImmediately!"

# "Bootstrap" account used before competition user provisioning.
bootstrap_user:
  username: "cyberrange"
  password: "Cyberrange123!"

# Accounts created on all Blue Team hosts.
blue_shared_users:
  - { name: "greyteam", password: "Hockey123!" }
  - { name: "scoring", password: "Hockey123!" }
  - { name: "cia", password: "ColdWar123!" }
  - { name: "kgb", password: "ColdWar123!" }

# Password applied to all Blue Team role-specific users.
blue_team_user_password: "Change.me123!"

# Windows WinRM local account on gold images (members + DC **before** promotion). See blue_windows.yml.
windows_local_winrm_password: "DeployWindows123!"

# After a host is promoted to **domain controller**, WinRM with local `ansible` is often rejected.
# Set to **true** so bardown (windows_dc) uses **ad_domain_join** (e.g. LAKEPLACID\greyteam) for Ansible.
# **true** = WinRM to bardown as LAKEPLACID\greyteam (required after DCPromo; local ansible is rejected).
# **false** = only for the first win_dc_dns run on a brand-new workgroup image. Most lab reruns use true.
windows_dc_winrm_use_domain_account: true

# OpenStack / tenant upstream DNS for non-AD lookups (apt mirrors, etc.). Split-DNS still routes
# lakeplacid.local to the team DC. On broken DHCP/neutron DNS, set this (e.g. ["10.0.0.2"]) or apt
# and realm discover fail even though /etc/resolv.conf shows 127.0.0.53.
openstack_dns_servers: []

# Write a systemd-resolved drop-in (/etc/systemd/resolved.conf.d/99-ad-split-dns.conf) so
# AD split-DNS survives reboots and NM refreshes without touching NM connection profiles.
nix_ad_persist_resolved_dropin: true
# Also push DC IP into the NM connection profile (additive — never removes DHCP DNS).
nix_ad_persist_dns_nmcli: true

# Linux AD join method:
# - adcli (default): strict per-team DC targeting (recommended for isolated teams sharing same domain name)
# - realm: DNS-based realm join path
nix_ad_join_method: "realm"

# After adcli join, run `realm join -U <ad_domain_join.username> --verbose <ad_domain>` so realmd/sssd
# stay in sync (realm list, realm permit). Uses ad_domain_join.password (e.g. Hockey123!).
nix_ad_realm_join_verbose_after_adcli: true

# Keep optional AD preflight validators disabled for faster/leaner runs.
# Set true only when actively troubleshooting DNS/discovery issues.
nix_ad_preflight_checks: false

# Mirror allowlisted domain users into libnss-extrausers (flat file under /var/lib/extrausers/passwd).
# If the libnss-extrausers package cannot be installed (e.g. 20.04 + bad mirror DNS), those steps skip.
nix_ad_nss_extrausers: true

# Active Directory (used for realm / domain join on members). Must match windows_dc.domain_name.
ad_domain: "lakeplacid.local"
# Credentials for joining members to AD (e.g. Domain Admin).
ad_domain_join:
  username: "greyteam"
  password: "Hockey123!"
</file>

<file path="group_vars/blue_linux.yml">
---
# Connection and privilege escalation — bootstrap user cyberrange (see all.yml → bootstrap_user).
# Domain join uses ad_domain_join (greyteam) inside nix_base for realm join -U only.
ansible_connection: ssh
ansible_user: "{{ bootstrap_user.username }}"
ansible_password: "{{ bootstrap_user.password }}"
ansible_become: true
ansible_become_method: sudo
ansible_become_password: "{{ bootstrap_user.password }}"
ansible_ssh_common_args: "-o StrictHostKeyChecking=no"

# Join Linux hosts to AD via realmd/sssd in nix_base (after DC is deployed).
nix_ad_domain_join: true
</file>

