<file path="roles/nix_base/tasks/ad_domain_join.yml">
---
# realmd/sssd AD join — Ubuntu 20.04 / 22.04 / 24.04 (desktop and server).
# OpenStack lab requirements:
# - Keep OpenStack DNS working (openstacklocal / apt mirrors)
# - Route lakeplacid.local to team DC using split DNS
# - Prefer strict per-DC targeting (adcli)

# Ubuntu 20.04 OpenStack images often use nova.clouds.archive.ubuntu.com; if that and archive.ubuntu.com
# do not resolve (stub resolver / wrong link DNS), apply openstack_dns_servers before apt.
- name: Default IPv4 interface for pre-AD-package DNS recovery
  ansible.builtin.shell: |
    set -euo pipefail
    ip -4 route show default | head -1 | awk '{for (i=1;i<=NF;i++) if ($i=="dev") {print $(i+1); exit}}'
  args:
    executable: /bin/bash
  register: nix_ad_pre_pkg_iface
  changed_when: false
  failed_when: false

- name: Probe DNS for OpenStack Ubuntu mirror host (sources.list on many cloud images)
  ansible.builtin.command: getent hosts nova.clouds.archive.ubuntu.com
  register: nix_probe_nova_mirror
  changed_when: false
  failed_when: false

- name: Probe DNS for archive.ubuntu.com when cloud mirror host does not resolve
  ansible.builtin.command: getent hosts archive.ubuntu.com
  register: nix_probe_archive_ubuntu
  changed_when: false
  failed_when: false
  when: nix_probe_nova_mirror.rc != 0

# Merge explicit openstack_dns_servers with per-link discovery (nmcli / resolvectl). No hard fail —
# 20.04 Desktop often has usable DHCP DNS in nmcli even when openstack_dns_servers is unset.
- name: Recover DNS for apt when cloud/archive mirrors do not resolve
  when:
    - nix_ad_pre_pkg_iface.stdout | default('') | trim | length > 0
    - nix_probe_nova_mirror.rc != 0
    - nix_probe_archive_ubuntu is not skipped
    - nix_probe_archive_ubuntu.rc != 0
  block:
    - name: Discover DNS via nmcli for pre-package apt recovery
      ansible.builtin.shell: |
        set -euo pipefail
        nmcli -g IP4.DNS device show "{{ nix_ad_pre_pkg_iface.stdout | trim }}" 2>/dev/null \
          | tr '|' '\n' \
          | sed 's/[[:space:]]//g' \
          | sed '/^$/d' \
          || true
      args:
        executable: /bin/bash
      register: nix_pkg_nmcli_dns
      changed_when: false
      failed_when: false

    - name: Discover DNS via resolvectl per-link for pre-package apt recovery
      ansible.builtin.shell: |
        set -euo pipefail
        resolvectl dns "{{ nix_ad_pre_pkg_iface.stdout | trim }}" 2>/dev/null \
          | sed -E 's/.*: *//' \
          | tr ' ' '\n' \
          | sed '/^$/d' \
          || true
      args:
        executable: /bin/bash
      register: nix_pkg_resolved_dns
      changed_when: false
      failed_when: false

    - name: Merge DNS candidates for apt (openstack + nmcli + resolvectl)
      ansible.builtin.set_fact:
        nix_ad_pkg_dns_candidates: >-
          {{
            (
              (openstack_dns_servers | default([]))
              + (nix_pkg_nmcli_dns.stdout_lines | default([]) | map('trim') | reject('equalto', '') | reject('equalto', '127.0.0.53') | list)
              + (nix_pkg_resolved_dns.stdout_lines | default([]) | map('trim') | reject('equalto', '') | reject('equalto', '127.0.0.53') | list)
            ) | unique | list
          }}

    - name: Apply merged DNS to default route interface for apt
      ansible.builtin.command:
        argv: "{{ ['resolvectl', 'dns', (nix_ad_pre_pkg_iface.stdout | trim)] + nix_ad_pkg_dns_candidates }}"
      when: nix_ad_pkg_dns_candidates | length > 0
      changed_when: true
      failed_when: false

    - name: Flush systemd-resolved caches after apt DNS recovery
      ansible.builtin.command: resolvectl flush-caches
      when: nix_ad_pkg_dns_candidates | length > 0
      changed_when: false
      failed_when: false

- name: Warn when mirror DNS still broken and no resolver IPs were found to apply
  ansible.builtin.debug:
    msg: >-
      Could not resolve nova.clouds.archive.ubuntu.com or archive.ubuntu.com, and no DNS servers were
      found from openstack_dns_servers, nmcli, or resolvectl. APT may still fail — set
      openstack_dns_servers in group_vars/all.yml (e.g. ['10.0.0.2']). On host: resolvectl status ; nmcli dev show
  when:
    - nix_probe_nova_mirror.rc != 0
    - nix_probe_archive_ubuntu is not skipped
    - nix_probe_archive_ubuntu.rc != 0
    - nix_ad_pkg_dns_candidates | default([]) | length == 0

# Do not block the play on apt-get update (common on 20.04 Desktop when mirrors/DNS are flaky).
- name: Update apt cache before AD packages (best effort)
  ansible.builtin.command:
    argv:
      - apt-get
      - update
  register: nix_ad_apt_cache_update
  failed_when: false
  changed_when: nix_ad_apt_cache_update.rc == 0

- name: Note when apt cache update failed (install still attempted)
  ansible.builtin.debug:
    msg: >-
      apt-get update failed on this host (rc={{ nix_ad_apt_cache_update.rc }}); continuing with
      package install without a fresh index. Fix DNS/mirrors if installs fail.
  when: nix_ad_apt_cache_update.rc != 0

- name: Install packages for AD domain join
  ansible.builtin.apt:
    name:
      - realmd
      - sssd
      - sssd-tools
      - libnss-sss
      - libpam-sss
      - adcli
      - samba-common-bin
      - oddjob-mkhomedir
      - krb5-user
      - ldap-utils
      - dnsutils
      - network-manager
    state: present
    update_cache: false
  register: nix_ad_join_packages_apt
  retries: 4
  delay: 15
  until: nix_ad_join_packages_apt is succeeded

# libnss-extrausers is optional: Ubuntu 20.04 Desktop + OpenStack often cannot fetch it when DNS to
# nova.clouds.archive.ubuntu.com fails — domain join does not require this package.
- name: Install libnss-extrausers for NSS passwd mirror (optional; non-fatal if apt cannot fetch)
  ansible.builtin.apt:
    name: libnss-extrausers
    state: present
    update_cache: false
  register: nix_ad_libnss_extrausers_pkg
  failed_when: false

- name: Detect whether libnss-extrausers is installed
  ansible.builtin.shell: |
    dpkg-query -W -f='${Status}' libnss-extrausers 2>/dev/null | grep -q 'install ok installed'
  args:
    executable: /bin/bash
  register: nix_libnss_extrausers_dpkg_check
  changed_when: false
  failed_when: false

- name: Record libnss-extrausers availability for extrausers nsswitch tasks
  ansible.builtin.set_fact:
    nix_libnss_extrausers_installed: "{{ nix_libnss_extrausers_dpkg_check.rc == 0 }}"

- name: Note skipping NSS extrausers mirror when package is not installed
  ansible.builtin.debug:
    msg: >-
      libnss-extrausers is not installed (apt fetch may have failed). Skipping extrausers nsswitch
      and flat passwd materialization; domain join and SSSD are unaffected.
  when:
    - nix_ad_nss_extrausers | default(true)
    - not (nix_libnss_extrausers_installed | default(false))

- name: Check current realm membership
  ansible.builtin.command: realm list
  register: nix_realm_list
  changed_when: false
  failed_when: false

- name: Start oddjobd for mkhomedir (if unit exists)
  ansible.builtin.systemd:
    name: oddjobd
    state: started
    enabled: true
  failed_when: false

- name: Domain-join preflight and join
  when: ad_domain | lower not in (nix_realm_list.stdout | default('') | lower)
  block:
    - name: Detect default IPv4 egress interface
      ansible.builtin.shell: |
        set -euo pipefail
        ip -4 route show default | head -1 | awk '{for (i=1;i<=NF;i++) if ($i=="dev") {print $(i+1); exit}}'
      args:
        executable: /bin/bash
      register: nix_default_iface
      changed_when: false
      failed_when: false

    - name: Fail if no default interface is detected
      ansible.builtin.fail:
        msg: >-
          [Preflight: network] Could not detect a default IPv4 interface.
          Fix host networking first, then rerun.
      when: nix_default_iface.stdout | default('') | trim | length == 0

    # nmcli -g outputs pipe-separated values on ONE line: "10.0.0.2 | 10.0.0.3 | 127.0.0.53"
    # Split on | and emit one IP per line so downstream filters work correctly.
    - name: Discover DNS via nmcli (preferred source)
      ansible.builtin.shell: |
        set -euo pipefail
        nmcli -g IP4.DNS device show "{{ nix_default_iface.stdout | trim }}" 2>/dev/null \
          | tr '|' '\n' \
          | sed 's/[[:space:]]//g' \
          | sed '/^$/d' \
          || true
      args:
        executable: /bin/bash
      register: nix_nmcli_dns
      changed_when: false
      failed_when: false

    - name: Discover DNS via resolvectl per-link (fallback source)
      ansible.builtin.shell: |
        set -euo pipefail
        resolvectl dns "{{ nix_default_iface.stdout | trim }}" 2>/dev/null \
          | sed -E 's/.*: *//' \
          | tr ' ' '\n' \
          | sed '/^$/d' \
          || true
      args:
        executable: /bin/bash
      register: nix_resolved_dns
      changed_when: false
      failed_when: false

    # Two separate set_fact tasks — nix_ad_resolvers must reference nix_upstream_resolvers
    # AFTER it is defined; referencing it in the same set_fact task causes "undefined" errors.
    - name: Build upstream resolver list
      ansible.builtin.set_fact:
        nix_upstream_resolvers: >-
          {{
            (
              (openstack_dns_servers | default([]))
              + (nix_nmcli_dns.stdout_lines | default([]) | map('trim') | reject('equalto', '') | reject('equalto', '127.0.0.53') | list)
              + (nix_resolved_dns.stdout_lines | default([]) | map('trim') | reject('equalto', '') | reject('equalto', '127.0.0.53') | list)
            ) | unique
          }}

    - name: Build AD resolver list (team DC first + upstream, deduplicated)
      ansible.builtin.set_fact:
        nix_ad_resolvers: "{{ ([team_domain_controller_ip] + nix_upstream_resolvers) | unique }}"

    - name: Assert upstream DNS is available (OpenStack env requirement)
      ansible.builtin.assert:
        that:
          - nix_upstream_resolvers | length > 0
        fail_msg: >-
          [Preflight: DNS upstream] No upstream DNS resolvers found.
          Define openstack_dns_servers in group_vars/all.yml (example:
          openstack_dns_servers: ['10.0.0.2','10.0.0.3']) when nmcli/resolvectl discovery is empty.
      when: nix_ad_preflight_checks | default(false)

    - name: Configure split-DNS resolvers (team DC first + upstream OpenStack DNS)
      ansible.builtin.command:
        argv: "{{ ['resolvectl', 'dns', (nix_default_iface.stdout | trim)] + nix_ad_resolvers }}"
      changed_when: true

    - name: Configure split-DNS search and routing domains for AD
      ansible.builtin.command:
        argv:
          - resolvectl
          - domain
          - "{{ nix_default_iface.stdout | trim }}"
          - "{{ ad_domain }}"
          - "~{{ ad_domain }}"
      changed_when: true

    - name: Flush systemd-resolved caches
      ansible.builtin.command: resolvectl flush-caches
      changed_when: false
      failed_when: false

    # Drop-in is the most reliable persistence: survives reboots, NM refreshes, DHCP renewals.
    # It does NOT change resolv.conf mode or remove existing resolvers — purely additive.
    - name: Create systemd-resolved drop-in directory
      ansible.builtin.file:
        path: /etc/systemd/resolved.conf.d
        state: directory
        owner: root
        group: root
        mode: "0755"
      when: nix_ad_persist_resolved_dropin | default(true)

    - name: Write systemd-resolved drop-in for AD split-DNS (reboot-safe)
      ansible.builtin.copy:
        dest: /etc/systemd/resolved.conf.d/99-ad-split-dns.conf
        owner: root
        group: root
        mode: "0644"
        content: |
          # Managed by Ansible (nix_base/ad_domain_join) — do not edit manually.
          [Resolve]
          # DC first so lakeplacid.local resolves even when public DNS is slow.
          DNS={{ (nix_ad_resolvers | join(' ')) }}
          # Route lakeplacid.local queries to DC; fall through to upstream for everything else.
          Domains={{ ad_domain }} ~{{ ad_domain }}
      register: nix_resolved_dropin
      when: nix_ad_persist_resolved_dropin | default(true)

    - name: Restart systemd-resolved to apply drop-in
      ansible.builtin.service:
        name: systemd-resolved
        state: restarted
      when:
        - nix_ad_persist_resolved_dropin | default(true)
        - nix_resolved_dropin is changed

    # Additive NM entry: adds DC IP to the connection's DNS list but keeps ignore-auto-dns OFF
    # so DHCP-provided resolvers (e.g. 1.1.1.1/8.8.8.8 from cloud-init) are preserved.
    - name: Persist DC IP in NetworkManager connection (additive, keeps DHCP DNS)
      ansible.builtin.shell: |
        set -euo pipefail
        iface="{{ nix_default_iface.stdout | trim }}"
        conn="$(nmcli -t -f GENERAL.CONNECTION device show "$iface" 2>/dev/null | sed -n 's/^GENERAL.CONNECTION://p' | head -1 | tr -d '\r')"
        conn="${conn#"${conn%%[![:space:]]*}"}"
        conn="${conn%"${conn##*[![:space:]]}"}"
        if [[ -z "$conn" || "$conn" == "--" ]]; then
          echo "nmcli_skip_no_connection"
          exit 0
        fi
        # Build a comma-separated list of DC + any explicit openstack_dns_servers.
        # ignore-auto-dns is deliberately left OFF (no) so cloud-init/DHCP DNS is additive.
        dc_ip="{{ team_domain_controller_ip }}"
        extra="{{ openstack_dns_servers | join(',') }}"
        if [[ -n "$extra" ]]; then
          dns_csv="${dc_ip},${extra}"
        else
          dns_csv="$dc_ip"
        fi
        nmcli connection modify "$conn" \
          ipv4.dns "$dns_csv" \
          ipv4.dns-priority -50 \
          ipv4.ignore-auto-dns no \
          ipv4.dns-search "{{ ad_domain }} ~{{ ad_domain }}"
        # reapply is safe here: ignore-auto-dns=no means DHCP DNS is still merged in.
        nmcli device reapply "$iface" 2>/dev/null || nmcli connection up "$conn" 2>/dev/null || true
        resolvectl flush-caches 2>/dev/null || true
        echo "nmcli_persisted=$conn"
      args:
        executable: /bin/bash
      register: nix_nmcli_dns_persist
      changed_when: "'nmcli_persisted=' in (nix_nmcli_dns_persist.stdout | default(''))"
      failed_when: false
      when: nix_ad_persist_dns_nmcli | default(true)

    - name: Validate AD A record via team DC
      ansible.builtin.command:
        argv:
          - dig
          - +short
          - "@{{ team_domain_controller_ip }}"
          - "{{ ad_domain }}"
      register: nix_dig_a
      changed_when: false
      failed_when: (nix_dig_a.stdout | trim | length) == 0
      when: nix_ad_preflight_checks | default(false)

    - name: Validate AD SRV record via team DC
      ansible.builtin.command:
        argv:
          - dig
          - +short
          - "@{{ team_domain_controller_ip }}"
          - "_ldap._tcp.dc._msdcs.{{ ad_domain }}"
          - SRV
      register: nix_dig_srv_dc
      changed_when: false
      failed_when: (nix_dig_srv_dc.stdout | trim | length) == 0
      when: nix_ad_preflight_checks | default(false)

    - name: Validate split-DNS resolver query for AD domain
      ansible.builtin.command:
        argv:
          - resolvectl
          - query
          - "{{ ad_domain }}"
      register: nix_resolvectl_query_domain
      changed_when: false
      failed_when: nix_resolvectl_query_domain.rc != 0
      when: nix_ad_preflight_checks | default(false)

    - name: Validate split-DNS resolver query for LDAP SRV
      ansible.builtin.command:
        argv:
          - resolvectl
          - query
          - "_ldap._tcp.{{ ad_domain }}"
          - "--type=SRV"
      register: nix_resolvectl_query_srv
      changed_when: false
      failed_when: nix_resolvectl_query_srv.rc != 0
      when: nix_ad_preflight_checks | default(false)

    - name: Validate adcli info against explicit team DC
      ansible.builtin.command:
        argv:
          - adcli
          - info
          - "{{ ad_domain }}"
          - "--domain-controller={{ team_domain_controller_ip }}"
      register: nix_adcli_info
      changed_when: false
      failed_when: nix_adcli_info.rc != 0
      when: nix_ad_preflight_checks | default(false)

    - name: Validate realm discovery through split DNS
      ansible.builtin.command:
        argv:
          - realm
          - discover
          - "{{ ad_domain }}"
      register: nix_realm_discover
      changed_when: false
      failed_when: nix_realm_discover.rc != 0
      when: nix_ad_preflight_checks | default(false)

  rescue:
    - name: Diagnostic - resolvectl status
      ansible.builtin.command: resolvectl status
      register: nix_diag_resolvectl_status
      changed_when: false
      failed_when: false
      when: nix_ad_preflight_checks | default(false)

    - name: Diagnostic - resolvectl dns iface
      ansible.builtin.command:
        argv:
          - resolvectl
          - dns
          - "{{ nix_default_iface.stdout | default('') | trim }}"
      register: nix_diag_resolvectl_dns
      changed_when: false
      failed_when: false
      when:
        - nix_ad_preflight_checks | default(false)
        - nix_default_iface is defined

    - name: Diagnostic - resolvectl domain iface
      ansible.builtin.command:
        argv:
          - resolvectl
          - domain
          - "{{ nix_default_iface.stdout | default('') | trim }}"
      register: nix_diag_resolvectl_domain
      changed_when: false
      failed_when: false
      when:
        - nix_ad_preflight_checks | default(false)
        - nix_default_iface is defined

    - name: Diagnostic - nmcli device show iface
      ansible.builtin.command:
        argv:
          - nmcli
          - device
          - show
          - "{{ nix_default_iface.stdout | default('') | trim }}"
      register: nix_diag_nmcli_dev
      changed_when: false
      failed_when: false
      when:
        - nix_ad_preflight_checks | default(false)
        - nix_default_iface is defined

    - name: Diagnostic - /etc/resolv.conf
      ansible.builtin.command:
        argv: [cat, /etc/resolv.conf]
      register: nix_diag_resolv_conf
      changed_when: false
      failed_when: false
      when: nix_ad_preflight_checks | default(false)

    - name: Fail with consolidated diagnostics
      ansible.builtin.fail:
        msg: |
          [AD join preflight/join failed] Host={{ inventory_hostname }} DC={{ team_domain_controller_ip }}
          Default iface: {{ nix_default_iface.stdout | default('n/a') | trim }}
          Upstream resolvers (ordered): {{ nix_upstream_resolvers | default([]) }}
          AD resolvers applied: {{ nix_ad_resolvers | default([]) }}
          Join method: {{ nix_ad_join_method | default('adcli') }}
          Define openstack_dns_servers if upstream resolvers are empty in OpenStack.

          --- resolvectl status ---
          {{ nix_diag_resolvectl_status.stdout | default('') }}
          {{ nix_diag_resolvectl_status.stderr | default('') }}

          --- resolvectl dns iface ---
          {{ nix_diag_resolvectl_dns.stdout | default('') }}
          {{ nix_diag_resolvectl_dns.stderr | default('') }}

          --- resolvectl domain iface ---
          {{ nix_diag_resolvectl_domain.stdout | default('') }}
          {{ nix_diag_resolvectl_domain.stderr | default('') }}

          --- nmcli device show iface ---
          {{ nix_diag_nmcli_dev.stdout | default('') }}
          {{ nix_diag_nmcli_dev.stderr | default('') }}

          --- /etc/resolv.conf ---
          {{ nix_diag_resolv_conf.stdout | default('') }}
          {{ nix_diag_resolv_conf.stderr | default('') }}
      when: nix_ad_preflight_checks | default(false)

- name: Create home directories for domain logins
  ansible.builtin.lineinfile:
    path: /etc/pam.d/common-session
    line: "session optional pam_mkhomedir.so skel=/etc/skel umask=0022"
    state: present
    create: false
  failed_when: false

# Domain Admins (AD group) + team admin accounts get sudo. Team local users are login-only (see permit/SSSD below).
- name: Allow Domain Admins and team admin users full sudo via SSSD
  ansible.builtin.copy:
    dest: /etc/sudoers.d/99-ad-domain-admins
    mode: "0440"
    content: |
      %Domain\ Admins@{{ ad_domain }} ALL=(ALL:ALL) ALL
      %domain\ admins@{{ ad_domain }} ALL=(ALL:ALL) ALL
      {% for u in (blue_team_admin_users | default([]) | unique) %}
      {{ u }}@{{ ad_domain }} ALL=(ALL:ALL) ALL
      {% endfor %}
    validate: "/usr/sbin/visudo -cf %s"

- name: Join with adcli (default strict per-DC) at end of AD flow
  ansible.builtin.shell: |
    set -euo pipefail
    domain='{{ ad_domain }}'
    dc='{{ team_domain_controller_ip }}'
    password='{{ ad_domain_join.password }}'
    u1='{{ ad_domain_join.username }}'
    u2='{{ ad_domain_join.username }}@{{ ad_domain }}'
    err="$(mktemp)"

    for u in "$u1" "$u2"; do
      if printf '%s\n' "$password" | adcli join --stdin-password --domain "$domain" --domain-controller "$dc" --login-user "$u" 2>"$err"; then
        echo "joined_with=$u"
        exit 0
      fi
    done

    echo "adcli join failed for both principal formats: $u1 and $u2" >&2
    cat "$err" >&2 || true
    exit 1
  args:
    executable: /bin/bash
  no_log: "{{ not (nix_ad_join_debug | default(false) | bool) }}"
  register: nix_realm_join
  when:
    - ad_domain | lower not in (nix_realm_list.stdout | default('') | lower)
    - (nix_ad_join_method | default('adcli')) == 'adcli'

# Registers the host with realmd (realm list / realm permit) and aligns sssd with what adcli wrote.
# Equivalent intent: sudo realm join -U 'greyteam' --verbose lakeplacid.local  (credentials from ad_domain_join).
- name: Verbose realm join after adcli (realmd enrollment)
  ansible.builtin.shell: |
    set -euo pipefail
    realm_name='{{ ad_domain }}'
    password='{{ ad_domain_join.password }}'
    u1='{{ ad_domain_join.username }}'
    u2='{{ ad_domain_join.username }}@{{ ad_domain }}'
    err="$(mktemp)"
    rl="$(realm list --name-only 2>/dev/null || true)"
    if printf '%s\n' "$rl" | grep -Fx "$realm_name" >/dev/null 2>&1; then
      echo "realm_already_listed=$realm_name"
      exit 0
    fi
    for u in "$u1" "$u2"; do
      if printf '%s\n' "$password" | realm join -U "$u" --verbose "$realm_name" 2>"$err"; then
        echo "realm_join_verbose_ok=$u"
        exit 0
      fi
      errtxt="$(cat "$err" || true)"
      if printf '%s' "$errtxt" | grep -Eiq 'already enrolled|already joined|already a member|Already configured'; then
        echo "realm_join_already=$u"
        exit 0
      fi
    done
    echo "verbose realm join failed for $u1 and $u2" >&2
    cat "$err" >&2 || true
    exit 1
  args:
    executable: /bin/bash
  no_log: "{{ not (nix_ad_join_debug | default(false) | bool) }}"
  register: nix_realm_verbose_join
  changed_when: "'realm_join_verbose_ok=' in (nix_realm_verbose_join.stdout | default(''))"
  failed_when: false
  when:
    - nix_ad_domain_join | default(false)
    - (nix_ad_join_method | default('adcli')) == 'adcli'
    - nix_ad_realm_join_verbose_after_adcli | default(true)

- name: Warn when verbose realm join after adcli failed (continuing)
  ansible.builtin.debug:
    msg: >-
      Optional realmd enrollment step failed after adcli join on {{ inventory_hostname }}.
      Continuing with domain-join flow. Set -e nix_ad_join_debug=true to reveal stderr for this task.
  when:
    - nix_realm_verbose_join is defined
    - nix_realm_verbose_join.rc is defined
    - nix_realm_verbose_join.rc != 0

- name: Restart SSSD after verbose realm join
  ansible.builtin.service:
    name: sssd
    state: restarted
  when:
    - nix_realm_verbose_join is defined
    - nix_realm_verbose_join is changed
  failed_when: false

- name: Join with realm (optional DNS-based path) at end of AD flow
  ansible.builtin.shell: |
    set -euo pipefail
    realm_name='{{ ad_domain }}'
    password='{{ ad_domain_join.password }}'
    u1='{{ ad_domain_join.username }}'
    u2='{{ ad_domain_join.username }}@{{ ad_domain }}'
    err="$(mktemp)"

    for u in "$u1" "$u2"; do
      if printf '%s\n' "$password" | realm join -U "$u" --verbose "$realm_name" 2>"$err"; then
        echo "joined_with=$u"
        exit 0
      fi
    done

    echo "realm join failed for both principal formats: $u1 and $u2" >&2
    cat "$err" >&2 || true
    exit 1
  args:
    executable: /bin/bash
  no_log: "{{ not (nix_ad_join_debug | default(false) | bool) }}"
  register: nix_realm_join
  when:
    - ad_domain | lower not in (nix_realm_list.stdout | default('') | lower)
    - (nix_ad_join_method | default('adcli')) == 'realm'

# --- Login allowlist (realm permit or SSSD simple_allow_users) ---
# All listed users may SSH/login. Team local users are non-sudo; sudo is only Domain Admins + blue_team_admin_users (see sudoers above).
# Combines admin + local team lists plus shared accounts (greyteam, scoring, ...).
- name: Build full team user list for realm permit and SSSD allowlist
  ansible.builtin.set_fact:
    nix_realm_permit_users: >-
      {{
        (blue_team_admin_users | default([]))
        + (blue_team_local_users | default([]))
        + (blue_shared_users | default([]) | map(attribute='name') | list)
      }}
  when: nix_ad_domain_join | default(false)

- name: Detect joined realm name for permit operations
  ansible.builtin.command: realm list --name-only
  register: nix_realm_list_names
  changed_when: false
  failed_when: false
  when: nix_ad_domain_join | default(false)

- name: Select effective realm name for permit
  ansible.builtin.set_fact:
    nix_effective_realm_name: >-
      {{
        (
          nix_realm_list_names.stdout_lines
          | default([])
          | map('trim')
          | reject('equalto', '')
          | list
          | first
        )
        | default(ad_domain, true)
      }}
  when: nix_ad_domain_join | default(false)

- name: Determine whether realmd has a joined realm for permit
  ansible.builtin.set_fact:
    nix_realmd_realm_available: >-
      {{
        (nix_realm_list_names.stdout_lines | default([]) | map('trim') | reject('equalto', '') | list | length) > 0
      }}
  when: nix_ad_domain_join | default(false)

# realm permit expects login principals (user@realm), not bare SAM names — see realmd "login format".
- name: Permit team domain users to log into this host via realm
  ansible.builtin.command:
    argv: "{{ ['realm', 'permit', '--realm', nix_effective_realm_name] + (nix_realm_permit_users | map('regex_replace', '$', '@' ~ ad_domain) | list) }}"
  register: nix_realm_permit
  changed_when: nix_realm_permit.rc == 0
  failed_when: nix_realm_permit.rc != 0
  when:
    - nix_ad_domain_join | default(false)
    - nix_realm_permit_users | default([]) | length > 0
    - nix_realmd_realm_available | default(false)

- name: Skip realm permit when host is adcli/sssd joined without realmd realm registration
  ansible.builtin.debug:
    msg: >-
      Skipping realm permit on {{ inventory_hostname }} because `realm list --name-only` is empty.
      AD connectivity can still be valid via adcli/sssd (for example adcli info works).
      To enforce explicit allowlists on these hosts, configure SSSD access controls.
  when:
    - nix_ad_domain_join | default(false)
    - nix_realm_permit_users | default([]) | length > 0
    - not (nix_realmd_realm_available | default(false))

- name: Build SSSD allowlist identities (user@domain) for adcli/sssd fallback
  ansible.builtin.set_fact:
    nix_sssd_allow_users: >-
      {{
        nix_realm_permit_users
        | default([])
        | map('regex_replace', '$', '@' ~ ad_domain)
        | list
      }}
  when:
    - nix_ad_domain_join | default(false)
    - nix_realm_permit_users | default([]) | length > 0
    - not (nix_realmd_realm_available | default(false))

- name: Enforce SSSD simple access provider when realm permit is unavailable
  ansible.builtin.ini_file:
    path: /etc/sssd/sssd.conf
    section: "domain/{{ ad_domain }}"
    option: access_provider
    value: simple
    mode: "0600"
    no_extra_spaces: true
  register: nix_sssd_access_provider
  when:
    - nix_ad_domain_join | default(false)
    - nix_sssd_allow_users | default([]) | length > 0
    - not (nix_realmd_realm_available | default(false))

- name: Set SSSD allowed users when realm permit is unavailable
  ansible.builtin.ini_file:
    path: /etc/sssd/sssd.conf
    section: "domain/{{ ad_domain }}"
    option: simple_allow_users
    value: "{{ nix_sssd_allow_users | join(',') }}"
    mode: "0600"
    no_extra_spaces: true
  register: nix_sssd_allow_users_cfg
  when:
    - nix_ad_domain_join | default(false)
    - nix_sssd_allow_users | default([]) | length > 0
    - not (nix_realmd_realm_available | default(false))

- name: Restart SSSD after domain join
  ansible.builtin.service:
    name: sssd
    state: restarted
  when:
    - (
        (nix_realm_join is defined and nix_realm_join is changed)
        or
        (nix_realm_verbose_join is defined and nix_realm_verbose_join is changed)
        or
        (nix_sssd_access_provider is defined and nix_sssd_access_provider is changed)
        or
        (nix_sssd_allow_users_cfg is defined and nix_sssd_allow_users_cfg is changed)
      )
  failed_when: false

# Flat passwd-style lines via libnss-extrausers (not realm; not editing /etc/passwd).
- name: Ensure nsswitch.conf includes extrausers after files for passwd
  ansible.builtin.shell: |
    set -euo pipefail
    if grep -qE '^passwd:[[:space:]]+files[[:space:]]+extrausers' /etc/nsswitch.conf; then
      echo "nsswitch_extrausers_already_present"
      exit 0
    fi
    cp -a /etc/nsswitch.conf "/etc/nsswitch.conf.bak.ansible-extrausers-$(date +%s)"
    sed -i 's/^\(passwd:[[:space:]]*files\)\([[:space:]]\)/\1 extrausers\2/' /etc/nsswitch.conf
    echo "nsswitch_extrausers_updated"
  args:
    executable: /bin/bash
  register: nix_nsswitch_extrausers_cmd
  when:
    - nix_ad_domain_join | default(false)
    - nix_ad_nss_extrausers | default(true)
    - nix_libnss_extrausers_installed | default(false)
    - nix_realm_permit_users | default([]) | length > 0
  changed_when: "'nsswitch_extrausers_updated' in (nix_nsswitch_extrausers_cmd.stdout | default(''))"

- name: Ensure extrausers directory and passwd file exist
  ansible.builtin.file:
    path: "{{ item.path }}"
    state: "{{ item.state }}"
    mode: "{{ item.mode }}"
  loop:
    - { path: /var/lib/extrausers, state: directory, mode: "0755" }
    - { path: /var/lib/extrausers/passwd, state: touch, mode: "0644" }
  when:
    - nix_ad_domain_join | default(false)
    - nix_ad_nss_extrausers | default(true)
    - nix_libnss_extrausers_installed | default(false)
    - nix_realm_permit_users | default([]) | length > 0

- name: Ensure SSSD is running before resolving domain users for extrausers
  ansible.builtin.service:
    name: sssd
    state: started
  register: nix_sssd_start_extrausers
  failed_when: false
  when:
    - nix_ad_domain_join | default(false)
    - nix_ad_nss_extrausers | default(true)
    - nix_libnss_extrausers_installed | default(false)
    - nix_realm_permit_users | default([]) | length > 0

- name: Diagnostic when SSSD did not start (extrausers path)
  ansible.builtin.command:
    argv:
      - journalctl
      - -u
      - sssd
      - -n
      - "40"
      - --no-pager
  register: nix_sssd_journal_tail
  changed_when: false
  failed_when: false
  when:
    - nix_ad_domain_join | default(false)
    - nix_ad_nss_extrausers | default(true)
    - nix_libnss_extrausers_installed | default(false)
    - nix_realm_permit_users | default([]) | length > 0
    - nix_sssd_start_extrausers is defined
    - not (nix_sssd_start_extrausers is succeeded)

- name: Debug SSSD journal tail after failed start
  ansible.builtin.debug:
    var: nix_sssd_journal_tail.stdout_lines
  when:
    - nix_ad_domain_join | default(false)
    - nix_ad_nss_extrausers | default(true)
    - nix_libnss_extrausers_installed | default(false)
    - nix_realm_permit_users | default([]) | length > 0
    - nix_sssd_start_extrausers is defined
    - not (nix_sssd_start_extrausers is succeeded)

- name: Materialize domain user lines into extrausers passwd (NSS-visible flat file)
  ansible.builtin.shell: |
    set -euo pipefail
    added=0
    for short in {{ nix_realm_permit_users | join(' ') }}; do
      u="${short}@{{ ad_domain }}"
      id "$u" >/dev/null 2>&1 || true
      line="$(getent passwd "$u" || true)"
      [ -n "$line" ] || continue
      if grep -qxF "$line" /var/lib/extrausers/passwd 2>/dev/null; then
        continue
      fi
      printf '%s\n' "$line" >> /var/lib/extrausers/passwd
      added=1
    done
    if [ "$added" -eq 1 ]; then
      echo "EXTRAUSERS_ADDED"
    fi
  args:
    executable: /bin/bash
  register: nix_extrausers_materialize
  changed_when: "'EXTRAUSERS_ADDED' in (nix_extrausers_materialize.stdout | default(''))"
  when:
    - nix_ad_domain_join | default(false)
    - nix_ad_nss_extrausers | default(true)
    - nix_libnss_extrausers_installed | default(false)
    - nix_realm_permit_users | default([]) | length > 0
    - nix_sssd_start_extrausers is defined
    - nix_sssd_start_extrausers is succeeded
</file>

