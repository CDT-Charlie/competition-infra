---
# Base Linux role - Common Linux system setup
# This role provides basic Linux configuration that other roles can depend on

- name: Detect default IPv4 interface for pre-APT DNS checks
  ansible.builtin.shell: |
    set -euo pipefail
    ip -4 route show default | head -1 | awk '{for (i=1;i<=NF;i++) if ($i=="dev") {print $(i+1); exit}}'
  args:
    executable: /bin/bash
  register: nix_default_iface_pre_apt
  changed_when: false
  failed_when: false

- name: Read /etc/resolv.conf nameservers (pre-APT)
  ansible.builtin.shell: |
    set -euo pipefail
    awk '/^nameserver / {print $2}' /etc/resolv.conf || true
  args:
    executable: /bin/bash
  register: nix_resolv_conf_nameservers
  changed_when: false
  failed_when: false

- name: Recover split DNS for apt when only 127.0.0.53 is present
  ansible.builtin.command:
    argv: "{{ ['resolvectl', 'dns', (nix_default_iface_pre_apt.stdout | trim)] + openstack_dns_servers }}"
  when:
    - openstack_dns_servers | default([]) | length > 0
    - nix_default_iface_pre_apt.stdout | default('') | trim | length > 0
    - (nix_resolv_conf_nameservers.stdout_lines | default([]) | length) == 1
    - (nix_resolv_conf_nameservers.stdout_lines | first) == "127.0.0.53"
  changed_when: true
  failed_when: false

# Ubuntu 20.04 OpenStack desktop: resolv.conf may not be stub-only yet mirrors still do not resolve.
- name: Probe Ubuntu mirror DNS before common packages
  ansible.builtin.command: getent hosts nova.clouds.archive.ubuntu.com
  register: nix_main_probe_nova
  changed_when: false
  failed_when: false

- name: Probe archive.ubuntu.com when cloud mirror host does not resolve
  ansible.builtin.command: getent hosts archive.ubuntu.com
  register: nix_main_probe_archive
  changed_when: false
  failed_when: false
  when: nix_main_probe_nova.rc != 0

- name: Recover per-link DNS for apt when mirrors do not resolve
  ansible.builtin.command:
    argv: "{{ ['resolvectl', 'dns', (nix_default_iface_pre_apt.stdout | trim)] + openstack_dns_servers }}"
  when:
    - openstack_dns_servers | default([]) | length > 0
    - nix_default_iface_pre_apt.stdout | default('') | trim | length > 0
    - nix_main_probe_nova.rc != 0
    - nix_main_probe_archive is not skipped
    - nix_main_probe_archive.rc != 0
  changed_when: true
  failed_when: false

- name: Flush resolved caches after mirror DNS recovery
  ansible.builtin.command: resolvectl flush-caches
  changed_when: false
  failed_when: false
  when:
    - openstack_dns_servers | default([]) | length > 0
    - nix_main_probe_nova.rc != 0
    - nix_main_probe_archive is not skipped
    - nix_main_probe_archive.rc != 0

# - name: Update apt cache (retry for transient mirror/DNS issues)
