<file path="roles/nix_web_stack/README.md">
## nginx container playbook 
### Developer: Caroline Richards
This script deploys nginx, MySQL, and php-fpm Docker container on a client and configures them on a network to communicate. Required files for nginx config, index.php, and database initialization are included in the directory but should but customized or replaced by themed, full web page implementations prior to competition deployment. Required files should be located in the same directory where the playbook is run.
</file>

<file path="roles/nix_web_stack/tasks/main.yml">
---
# Author: Caroline Richards
# Email: cpr9499@rit.edu

# This playbook deploys a web stack on a Linux host with Nginx, MySQL, and PHP
- name: Install Nginx, MySQL, and PHP packages
  apt: 
    name: 
      - nginx
      - mysql-server
      - php-fpm
      - php-mysql
    state: present
    update_cache: yes

# PHP
- name: Start and enable PHP-FPM
  service:
    name: php7.4-fpm
    state: started
    enabled: yes

# Nginx Setup
- name: Start and enable Nginx
  service: 
    name: nginx
    state: started
    enabled: yes

- name: Ensure web root directory exists
  file:
      path: "{{ web_stack.web_root }}"
      state: directory
      owner: www-data
      group: www-data
      mode: '0755'

- name: Copy website files
  copy: 
    src: "{{ item }}"
    dest: "{{ web_stack.web_root }}/{{ item }}"
    owner: www-data
    group: www-data
    mode: '0644'
  loop:
    - index.php
    - config.php
    - style.css
    - score.php

- name: Copy Nginx configuration
  copy: 
    src: nginx.conf
    dest: /etc/nginx/sites-available/miracle_ice
    mode: '0644'

- name: Enable nginx site
  file: 
    src: /etc/nginx/sites-available/miracle_ice
    dest: /etc/nginx/sites-enabled/miracle_ice
    state: link

- name: Remove default nginx site
  file: 
    path: /etc/nginx/sites-enabled/default
    state: absent

- name: Restart Nginx 
  service: 
    name: nginx
    state: restarted

# MySQL Setup
- name: Install python MySQL dependency
  apt:
    name: python3-pymysql
    state: present

- name: Start and enable MySQL
  service:
    name: mysql
    state: started
    enabled: yes

- name: Copy SQL setup script
  copy:
    src: mysql_setup.sql
    dest: /tmp/mysql_setup.sql
    mode: '0644'

- name: Create database
  community.mysql.mysql_db:
    name: miracle_ice
    state: present
    login_unix_socket: /var/run/mysqld/mysqld.sock

- name: Import SQL setup script
  community.mysql.mysql_db:
    name: miracle_ice
    state: import
    target: /tmp/mysql_setup.sql
    login_unix_socket: /var/run/mysqld/mysqld.sock

- name: Create Database user
  community.mysql.mysql_user:
    name: "{{ web_stack.mysql.app_user }}"
    password: "{{ web_stack.mysql.app_password }}"
    priv: "miracle_ice.*:ALL"
    host: localhost
    state: present
    login_unix_socket: /var/run/mysqld/mysqld.sock
</file>

<file path="roles/win_base/tasks/main.yml">
---
# Base Windows role - Common Windows system setup
# This role provides basic Windows configuration that other roles can depend on

- name: Ensure WinRM service is enabled and running
  ansible.windows.win_service:
    name: WinRM
    start_mode: auto
    state: started

- name: Enable File and Printer Sharing firewall rules
  ansible.windows.win_powershell:
    script: |
      Set-NetFirewallRule -DisplayGroup "File and Printer Sharing" -Enabled True

- name: Enable Powershell Script Execution
  win_shell: Set-ExecutionPolicy -ExecutionPolicy Unrestricted -Force

# Administrators are elevated silently instead of getting a UAC prompt for credentials
- name: Disable UAC for Administrators Only
  win_regedit:
    path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
    name: ConsentPromptBehaviorAdmin
    data: 0  # elevates without prompting for Administrators
    type: dword

# Checks the local Windows group Remote Management Users exists
- name: Ensure Remote Management Group Exists
  ansible.windows.win_group:
    name: "Remote Management Users"
    state: present

# Makes Remote Desktop allowed
- name: Set fDenyTSConnections
  ansible.windows.win_regedit:
    path: HKLM:\System\CurrentControlSet\Control\Terminal Server
    name: fDenyTSConnections
    data: 0
    type: dword
    state: present

# Sets another Terminal Services registry value, to keep Remote Desktop status/settings in sync
- name: Set updateRDStatus
  ansible.windows.win_regedit:
    path: HKLM:\System\CurrentControlSet\Control\Terminal Server
    name: updateRDStatus
    data: 1
    type: dword
    state: present

- name: Create RDP (TCP) Exception In Firewall (Windows > 7/2012)
  community.windows.win_firewall_rule:
    name: RDP
    protocol: tcp
    localport: 3389
    action: allow
    direction: in
    state: present
    profiles:
    - domain
    - private
    - public
    localip: any
    remoteip: any
    enabled: yes
  when: ansible_distribution_major_version|int > 6

- name: Create RDP (UDP) Exception in Firewall (Windows > 7/2012)
  community.windows.win_firewall_rule:
    name: RDP
    protocol: udp
    localport: 3389
    action: allow
    direction: in
    state: present
    profiles:
    - domain
    - private
    - public
    localip: any
    remoteip: any
    enabled: yes
  when: ansible_distribution_major_version|int > 6

# For older Windows versions, instead of creating explicit firewall rules, enables the built-in firewall rule group for Remote Desktop using netsh
- name: Create RDP Exception in Firewall (<= Windows 7/2012)
  ansible.windows.win_command: cmd.exe
  args:
    stdin: 'netsh advfirewall firewall set rule group="remote desktop" new enable=Yes'
  when: ansible_distribution_major_version|int <= 6
</file>

